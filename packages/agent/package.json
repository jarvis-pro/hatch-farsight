{
  "name": "@farsight/agent",
  "version": "0.1.0",
  "description": "Farsight 页面 agent —— console/network/error/event 劫持 + rrweb 画面镜像，?debug= 时懒加载、零业务依赖",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rrweb/record": "^2.1.0"
  },
  "devDependencies": {
    "@farsight/protocol": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "~5.7.2"
  }
}
