{
  "name": "hatch-farsight",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "farsight": "./packages/cli/bin.mjs"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm run build && pnpm -r run typecheck",
    "start": "node packages/cli/bin.mjs",
    "dev:viewer": "pnpm --filter @farsight/viewer dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "catalog:",
    "typescript-eslint": "^8.62.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}
