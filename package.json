{
  "name": "hatch-farsight",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "farsight": "./packages/cli/bin.mjs"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm run build && pnpm -r run typecheck",
    "start": "node packages/cli/bin.mjs",
    "dev:viewer": "pnpm --filter @farsight/viewer dev"
  },
  "devDependencies": {
    "typescript": "~5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}
